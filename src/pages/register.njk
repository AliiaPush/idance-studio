---
pagination:
  data: collections.register
  size: 1
  alias: form
permalink: "{{  form.data.path | slug }}/index.html"
---
<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="We at IDance studio aimed at making dance an accessible and enjoyable activity for children everywhere.">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Jockey+One&family=Kaisei+HarunoUmi:wght@500;700&display=swap" rel="stylesheet">
        <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"/>
        <link rel="shortcut icon" href="../assets/images/favicon.svg" type="icon">
        <link rel="stylesheet" href="../assets/styles/style.css">
        <script src="https://kit.fontawesome.com/4e769e3898.js" crossorigin="anonymous"></script>
        <script type="module" src="../assets/js/main.js" defer></script>
        <title>Idance Studio | Class Registration</title>
    </head>

    <body id="body">

        <div id="spinner" class="spinner-container">
            <div class="spinner"></div>
        </div>
        <!-- navbar  -->
        {% set background = "true" %}
        {% include "../_includes/nav.njk" %}
        <!-- navbar  -->
        <!-- alert -->
        <div id="alert" class="alert">
            <!-- success  -->
            <div id="alert-success" class="alert-text-box">
                <i class="fa-regular fa-circle-check alert-text-icon"></i>
                <p data-alert-text="success" class="alert-text">This is a sample alert</p>
            </div>
            <!-- success -->
            <!-- error  -->
            <div id="alert-error" class="alert-text-box">
                <i class="fa-regular fa-circle-xmark alert-text-icon"></i>
                <p data-alert-text="error" class="alert-text">This is a sample alert</p>
            </div>
            <!-- error -->
            <button id="alert-close-btn" class="alert-close-btn">
                <i class="fa-solid fa-xmark alert-close-icon"></i>
            </button>
        </div>
        <!-- alert  -->
        <!-- contact  -->
        <section id="contact" class="contact-us container">
            <!-- page topic  -->
            <div class="page-topic-container">
                <h3 class="page-topic" data-key-text="register.title">
                    {% for item1 in collections.navigations %}{{ item1.data.classRegistration.en }}
                    {% endfor %}
                </h3>
            </div>
            <!-- page topic  -->
            {% for item in collections.register %}
                <div class="form">
                    <div class="form-items">
                        <!-- form item  -->
                        <div class="form-item form-item-half">
                            <div class="form-input-label-container">
                                <label for="first-name" class="form-input-label" data-key-text="register.data.first-name.title">
                                    {{ item.data.firstName.title.en }}
                                </label>
                            </div>
                            <div class="form-input-container">
                                <input data-key-input="register.data.first-name.placeholder" id="first-name" type="text" class="form-input"
                            placeholder="{{ item.data.firstName.placeholder.en }}">
                            </div>
                        </div>
                        <!-- form item  -->
                        <!-- form item  -->
                        <div class="form-item form-item-half">
                            <div class="form-input-label-container">
                                <label for="last-name" class="form-input-label" data-key-text="register.data.last-name.title">
                                    {{ item.data.lastName.title.en }}
                                </label>
                            </div>
                            <div class="form-input-container">
                                <input data-key-input="register.data.last-name.placeholder" id="last-name" type="text" class="form-input"
                            placeholder="{{ item.data.lastName.placeholder.en }}">
                            </div>
                        </div>
                        <!-- form item  -->
                        <!-- form item  -->
                        <div class="form-item form-item-half">
                            <div class="form-input-label-container">
                                <label for="mobile-number" class="form-input-label" data-key-text="register.data.mobile.title">
                                    {{ item.data.mobile.title.en }}
                                </label>
                            </div>
                            <div class="form-input-container">
                                <input data-key-input="register.data.mobile.placeholder" id="mobile-number" type="text" class="form-input"
                            placeholder="{{ item.data.mobile.placeholder.en }}">
                            </div>
                        </div>
                        <!-- form item  -->
                        <!-- form item  -->
                        <div class="form-item form-item-half">
                            <div class="form-input-label-container">
                                <label for="age" class="form-input-label" data-key-text="register.data.age.title">
                                    {{ item.data.age.title.en }}
                                </label>
                            </div>
                            <div class="form-input-container">
                                <input data-key-input="register.data.age.placeholder" id="age" type="text" class="form-input"
                            placeholder="{{ item.data.age.placeholder.en }}">
                            </div>
                        </div>
                        <!-- form item  -->
                        <!-- form item  -->
                        <div class="form-item form-item-full">
                            <div class="form-input-label-container">
                                <p for="class-location" class="form-input-label" data-key-text="register.data.location.title">
                                    {{ item.data.location.title.en }}
                                </p>
                            </div>
                            <div class="form-input-container">
                                <!-- selector  -->
                                <div data-selector-contain="location" id="class-location" class="form-select">
                                    <input data-mulitple data-selector-checkbox="location" type="checkbox" value="" class="selector-checkbox" id="location">
                                    <label for="location" class="form-select-label">
                                        <p id="class-location-value" data-selected-value="location" class="form-selected-text"
                                data-key-text="register.data.location.options.0">
                                            {{ item.data.location.placeholder.en }}
                                        </p>
                                        <div class="form-select-arrow">
                                            <span data-selector-arrow="class-location" class="material-symbols-outlined form-select-arrow-icon">
                                    expand_more
                                </span>
                                        </div>
                                    </label>

                                    <!-- options  -->
                                    <div class="form-options">
                                        {% for option in item.data.location.options %}
                                            <!-- option  -->
                                            <label for="checkbox-location-{{ loop.index0 }}" data-option class="option-container">
                                                <p data-option-value="{{ loop.index0 }}" class="option" data-key-option="register.data.location.options.{{ loop.index0 }}">
                                                    {{ option.en }}
                                                </p>
                                                {% if loop.index0 != 0 %}
                                                    <div class="option-checkbox-container">
                                                        <input 
                                                        data-selector-option="location" 
                                                        data-selector-value="{{ option.en }}" 
                                                        type="checkbox" id="checkbox-location-{{ loop.index0 }}" 
                                                        class="option-checkbox">
                                                        <span class="material-symbols-outlined option-check">
                                                            check
                                                        </span>
                                                    </div>
                                                {% endif %}
                                            </label>
                                            <!-- option  -->
                                        {% endfor %}
                                    </div>
                                    <!-- options  -->
                                </div>
                                <!-- selector  -->
                            </div>
                        </div>
                        <!-- form item  -->
                        <!-- form item  -->
                        <div class="form-item form-item-full">
                            <div class="form-input-label-container">
                                <label for="email" class="form-input-label" data-key-text="register.data.email.title">
                                    {{ item.data.email.title.en }}
                                </label>
                            </div>
                            <div class="form-input-container">
                                <input data-key-input="register.data.email.placeholder" id="email" type="email" class="form-input"
                            placeholder="{{ item.data.email.placeholder.en }}">
                            </div>
                        </div>
                        <!-- form item  -->
                        <!-- form item  -->
                        <div class="form-item form-item-full">
                            <div class="form-input-label-container">
                                <label for="message" class="form-input-label" data-key-text="register.data.details.title">
                                    {{ item.data.details.title.en }}
                                </label>
                            </div>
                            <div class="form-input-container">
                                <textarea data-key-input="register.data.details.placeholder" id="message" type="text" rows="10" class="form-input"
                            placeholder="{{ item.data.details.placeholder.en }}"></textarea>
                            </div>
                        </div>
                        <!-- form item  -->
                    </div>
                    <button id="send" class="form-send-btn" data-key-text="register.data.send.title">
                        {% for item1 in collections.navigations %}{{ item1.data.send.en }}
                        {% endfor %}
                    </button>
                </div>
            {% endfor %}
        </section>
        <!-- contact  -->
        <!-- footer  -->
        {% include "../_includes/footer.njk" %}
        <!-- footer  -->
    </body>

</html>